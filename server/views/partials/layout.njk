{# For source of govuk/template.njk see: https://github.com/alphagov/govuk-frontend/blob/main/packages/govuk-frontend/src/govuk/template.njk #}
{% extends "govuk/template.njk" %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
{% endblock %}

{% block pageTitle %}{{pageTitle | default(applicationName)}}{% endblock %}

{% block bodyStart %}
  {% include "./cookieBanner.njk" %}
{% endblock %}

{% block header %}
  {% include "./header.njk" %}
{% endblock %}

{% block govukFooter %}
  {% include "./footer.njk" %}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
{% endblock %}
