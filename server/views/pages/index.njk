      {% else %}
        <p>No data.</p>
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}
{% if props.standards | length %}
<section>
  <h2 class="govuk-heading-l">Standards</h2>
  <div class="govuk-width-container">
    <ul class="govuk-grid-row card-group">
      {% for item in props.standards %}
        <li class="govuk-grid-column-one-third card-group__item">
          {{ card({
            title: item.title,
            description: item.description,
            url: item.url,
            showDepartment: true,
            department: item.department
          }) }}
        </li>
      {% else %}
        <p>No data.</p>
