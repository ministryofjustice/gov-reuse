</section>
{% endif %}
{% if props.servicePatterns | length %}
<section>
  <h2 class="govuk-heading-l">Service patterns</h2>
  <div class="govuk-width-container">
    <ul class="govuk-grid-row card-group">
      {% for item in props.servicePatterns %}
        <li class="govuk-grid-column-one-third card-group__item">
          {{ card({
