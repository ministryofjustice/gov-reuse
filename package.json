{
  "name": "gov-reuse-library",
  "version": "0.1.0",
  "description": "GOV Reuse Library",
  "repository": "git@github.com:ministryofjustice/gov-reuse.git",
  "license": "MIT",
  "scripts": {
    "build": "node esbuild/esbuild",
    "clean": "rm -rf dist test_results",
    "housekeeping": "npm audit && npm run validate:all && npx sort-package-json",
    "int-test": "npx playwright test",
    "int-test-init:ci": "npx playwright install",
    "int-test-ui": "npx playwright test --ui",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "precommit:lint": "lint-staged",
    "precommit:secrets": "gitleaks git --pre-commit --redact --staged --verbose --config .gitleaks/config.toml --gitleaks-ignore-path .gitleaks/.gitleaksignore",
    "precommit:verify": "npm run typecheck && npm test",
    "prepare": "hmpps-precommit-hooks-prepare",
    "rebuild": "npm run clean && npm run setup && npm run build",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "setup": "npm ci && hmpps-npm-script-run-allowlist",
    "spellcheck": "cspell lint --gitignore --no-must-find-files --unique --no-progress --show-suggestions --color **/*",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start-feature": " node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "start-feature:dev": "node esbuild/esbuild --watch --env feature.env",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "typecheck": "tsc && tsc -p integration_tests",
    "validate:all": "npm run validate:ts && npm run lint && npm run validate:yml && npm run validate:md",
    "validate:md": "npx markdownlint-cli --config .markdownlint.json \"**/*.md\"",
    "validate:ts": "npx tsc --noEmit --project ./tsconfig.json",
    "validate:yml": "npx yaml-lint **/*.yml --ignore=**/node_modules",
    "watch-ts": "tsc -w"
  },
  "overrides": {
    "tar": "^7.5.8"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1028.0",
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-auth-clients": "^1.0.2",
    "@ministryofjustice/hmpps-monitoring": "^1.0.2",
    "@ministryofjustice/hmpps-rest-client": "^1.0.0",
    "applicationinsights": "^3.14.0",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "dompurify": "3.3.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "jsdom": "29.0.0",
    "jwt-decode": "^4.0.0",
    "marked": "17.0.4",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^5.11.0",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.2",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "@ministryofjustice/hmpps-precommit-hooks": "^2.0.2",
    "@playwright/test": "^1.59.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/dompurify": "3.2.0",
    "@types/express-session": "^1.18.2",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "cspell": "^9.8.0",
    "del": "8.0.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "0.48.0",
    "nock": "^14.0.12",
    "sort-package-json": "^3.6.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "yaml-lint": "^1.7.0"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  }
}
